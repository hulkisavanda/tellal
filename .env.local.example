# Sekans worker: GET /api/cron/sequences — Authorization: Bearer <CRON_SECRET>
# Vercel Cron bu uç noktayı çağırır; CRON_SECRET proje ortamında tanımlı olmalı.
CRON_SECRET=

# Geliştirme: ödeme kontrolünü gevşet (production'da true yapmayın)
ALLOW_UNPAID_ACCESS=false
