IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

META_APP_ID=
META_APP_SECRET=
# Webhook doğrulama (Meta Developer Console → Webhooks)
META_VERIFY_TOKEN=
# Leadgen detayı için (Graph API — sayfa erişim jetonu)
META_PAGE_ACCESS_TOKEN=
# İsteğe bağlı, örn. v21.0
META_GRAPH_API_VERSION=v21.0

# Google lead webhook (özel entegrasyon; tek paylaşılan gizli anahtar)
